# Supabase (https://supabase.com/dashboard)
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key

# App URL (used in invite links and confirmation emails)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Gemini (resume parsing)
GEMINI_API_KEY=your-gemini-api-key

# Parse rate limit (optional — defaults: 8 requests per 15 minutes per invite token)
# PARSE_RATE_LIMIT_MAX=8
# PARSE_RATE_LIMIT_WINDOW_MS=900000

# Resend (confirmation emails) — https://resend.com
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=onboarding@resend.dev
